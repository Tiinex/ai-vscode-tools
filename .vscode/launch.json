{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Agent Architect Tools Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/sandboxed-workspace"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "build agent architect tools extension"
    }
  ]
}