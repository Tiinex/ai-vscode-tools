{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tiinex AI VS Code Tools Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "watch ai vscode tools extension"
    }
  ]
}